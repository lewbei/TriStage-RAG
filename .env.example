# TriStage-RAG environment variables.
# Copy to `.env` and fill in the values you need. All variables are optional
# unless you use gated models.

# ---------------------------------------------------------------------------
# Hugging Face Hub token
# ---------------------------------------------------------------------------
# Required only if you use gated models (e.g. google/embeddinggemma-300m).
# Without it, Stage 1 falls back to the public all-MiniLM-L6-v2 automatically.
# Both variable names are accepted; HF_TOKEN takes precedence.
HUGGING_FACE_HUB_TOKEN=
HF_TOKEN=

# ---------------------------------------------------------------------------
# Web UI (non_mcp/webui/app.py)
# ---------------------------------------------------------------------------
# Flask session secret. CHANGE THIS for any non-local deployment.
# Defaults to "dev-secret" (the UI binds to 127.0.0.1 only).
NON_MCP_WEBUI_SECRET=dev-secret

# Device override for the web UI's pipeline (auto | cuda | cpu).
NON_MCP_DEVICE=auto

# Logging knobs for the web UI.
NON_MCP_LOG_LEVEL=INFO
NON_MCP_WEBUI_LOG_LEVEL=INFO
NON_MCP_WEBUI_LOG_FILE=non_mcp_webui.log

# ---------------------------------------------------------------------------
# NOTE on TRISTAGE_* and LOG_LEVEL
# ---------------------------------------------------------------------------
# The README documents TRISTAGE_DEVICE, TRISTAGE_LOW_MEMORY, TRISTAGE_SAMPLE_SIZE
# and LOG_LEVEL. As of this release these are NOT yet wired into the code —
# benchmark behavior is controlled by benchmark/config.yaml, and the pipeline by
# mcp/config.yaml (or the PipelineConfig dataclass). See KNOWN_ISSUES.md.
